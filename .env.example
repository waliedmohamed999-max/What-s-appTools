# Server port
PORT=3000

# Persistent storage. Leave blank locally; container deployments set this to a mounted volume.
STORAGE_DIR=

# When the frontend is hosted separately (for example on Vercel), list its exact HTTPS origins.
# Multiple origins are comma-separated. PUBLIC_APP_URL is used after Meta OAuth redirects.
FRONTEND_ORIGINS=
PUBLIC_APP_URL=
# Trust one upstream proxy (Render/nginx). Leave false when exposing Docker directly.
TRUST_PROXY=false

# There is no login screen — DMS has no accounts and is meant to run somewhere only you
# can reach it. Do not expose a deployment's URL publicly.

# Test/diagnostic switch. Keep false in a real WhatsApp deployment.
DMS_DISABLE_WHATSAPP=false

# Optional system Chromium path used by Docker/VPS deployments.
PUPPETEER_EXECUTABLE_PATH=

# Default country code used when a phone number starts with "0" (local format)
DEFAULT_COUNTRY_CODE=966

# Delay between individual messages, in milliseconds (randomized between MIN and MAX)
# Hard floor of 2000ms is always enforced by the app regardless of these values.
MIN_DELAY_MS=3000
MAX_DELAY_MS=8000

# Number of messages sent before pausing the batch
BATCH_SIZE=20

# Pause duration between batches, in milliseconds (30-60s recommended)
BATCH_PAUSE_MS=45000

# Meta (Facebook/Instagram) app credentials for the Content Scheduler's real publish
# integration. Leave empty to leave that feature disabled. See README > "Real publishing
# to Facebook & Instagram" for how to create your own Meta app and fill these in.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/meta/callback
# Override only while migrating between supported Meta Graph API versions.
META_GRAPH_VERSION=v25.0
# Public HTTPS base URL for this server (e.g. an ngrok URL or real domain).
# Required only for Instagram publishing — Facebook publishing works without it.
META_PUBLIC_BASE_URL=
# Optional dedicated HMAC secret for ten-minute Instagram media links.
# Defaults to META_APP_SECRET when left empty.
MEDIA_SIGNING_SECRET=

# Frontend build-time setting (set this in Vercel, not in a public client-side secret).
# Example: https://your-dms-backend.example.com
DMS_API_BASE_URL=
