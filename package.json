{
  "name": "whatsapp-bulk-sender",
  "version": "1.0.0",
  "description": "Standalone tool to send one message to a list of phone numbers imported from Excel, via WhatsApp Web QR pairing.",
  "private": true,
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "generate:template": "node scripts/generateSampleExcel.js"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "whatsapp-web.js": "^1.26.0",
    "xlsx": "^0.18.5"
  }
}
