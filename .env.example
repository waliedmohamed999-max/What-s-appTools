# Server port
PORT=3000

# Default country code used when a phone number starts with "0" (local format)
DEFAULT_COUNTRY_CODE=966

# Delay between individual messages, in milliseconds (randomized between MIN and MAX)
# Hard floor of 2000ms is always enforced by the app regardless of these values.
MIN_DELAY_MS=3000
MAX_DELAY_MS=8000

# Number of messages sent before pausing the batch
BATCH_SIZE=20

# Pause duration between batches, in milliseconds (30-60s recommended)
BATCH_PAUSE_MS=45000

# Meta (Facebook/Instagram) app credentials for the Content Scheduler's real publish
# integration. Leave empty to leave that feature disabled. See README > "Real publishing
# to Facebook & Instagram" for how to create your own Meta app and fill these in.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/meta/callback
# Public HTTPS base URL for this server (e.g. an ngrok URL or real domain).
# Required only for Instagram publishing — Facebook publishing works without it.
META_PUBLIC_BASE_URL=
